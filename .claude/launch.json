{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Python HTTP (LAN)",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8000", "--bind", "0.0.0.0"],
      "port": 8000
    },
    {
      "name": "Vercel Dev",
      "runtimeExecutable": "vercel",
      "runtimeArgs": ["dev", "--listen", "3000"],
      "port": 3000
    },
    {
      "name": "Serve (npx)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["--yes", "serve", "-l", "3001", "."],
      "port": 3001
    }
  ]
}
